{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend-react/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/index.js"
    },
    {
      "src": "/ping-db",
      "dest": "api/index.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/tickets/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-react/dist/$1"
    }
  ]
}