{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend-react/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "backend/app.js"
    },
    {
      "src": "/ping-db",
      "dest": "backend/app.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "backend/app.js"
    },
    {
      "src": "/tickets",
      "dest": "backend/app.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/tickets/(.*)",
      "dest": "backend/app.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "backend/app.js"
    },
    {
      "src": "/calendar/(.*)",
      "dest": "backend/app.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/app.js"
    },
    {
      "src": "/",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/login",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/register",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/tickets",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/stats",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/recuperar",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/reset/(.*)",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/tareas/(.*)",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-react/dist/$1"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://tareasync.vercel.app/$1",
      "statusCode": 301
    }
  ]
}
